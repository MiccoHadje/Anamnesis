{
  "transcripts_root": "~/.claude/projects",
  "exclude_projects": [],
  "exclude_sessions": [],
  "search_mode": "hybrid",
  "max_embedding_chars": 8000,
  "database": {
    "host": "localhost",
    "port": 5432,
    "database": "anamnesis",
    "user": "anamnesis",
    "password": ""
  },
  "ollama": {
    "url": "http://localhost:11434",
    "model": "bge-m3"
  },
  "topic_model": {
    "url": "http://localhost:11434",
    "model": "gemma3:12b",
    "strategy": "full",
    "preserve_words": ["dash", "key", "state"]
  },
  "concurrency": {
    "embedding": 4,
    "topics": 2
  },
  "tasks": {
    "provider": "nudge",
    "nudge": {
      "host": "localhost",
      "port": 5432,
      "database": "nudge",
      "user": "anamnesis"
    }
  },
  "reporting": {
    "projects": [
      {
        "name": "MyProject",
        "anamnesis_project": "MyProject",
        "daily_log_dir": "docs/daily",
        "nudge_project": "@MyProject"
      }
    ],
    "reports_dir": "~/.claude/reports"
  }
}
