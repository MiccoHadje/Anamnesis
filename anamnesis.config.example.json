{
  "transcripts_root": "~/.claude/projects",
  "exclude_projects": [],
  "exclude_sessions": [],
  "search_mode": "hybrid",
  "max_embedding_chars": 8000,
  "database": {
    "host": "localhost",
    "port": 5432,
    "database": "anamnesis",
    "user": "anamnesis",
    "password": ""
  },
  "ollama": {
    "url": "http://localhost:11434",
    "model": "bge-m3"
  },
  "topic_model": {
    "url": "http://localhost:11434",
    "model": "gemma3:12b",
    "strategy": "full",
    "preserve_words": ["dash", "key", "state"]
  },
  "concurrency": {
    "embedding": 4,
    "topics": 2
  },
  "tasks": {
    "provider": "github",
    "github": {
      "repos": {
        "MyProject": "myuser/my-project"
      },
      "blocked_label": "blocked"
    }
  },
  "_tasks_todoist_example": {
    "provider": "todoist",
    "todoist": {
      "api_token": "your-api-token-from-todoist-settings",
      "projects": {
        "MyProject": "todoist-project-id"
      },
      "blocked_label": "blocked"
    }
  },
  "_tasks_linear_example": {
    "provider": "linear",
    "linear": {
      "api_key": "lin_api_your-key-here",
      "teams": {
        "MyProject": "team-key-or-id"
      },
      "blocked_label": "blocked"
    }
  },
  "reporting": {
    "projects": [
      {
        "name": "MyProject",
        "anamnesis_project": "MyProject",
        "daily_log_dir": "docs/daily",
        "task_project": "MyProject"
      }
    ],
    "reports_dir": "~/.claude/reports"
  }
}
